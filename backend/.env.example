# Copy this file to .env and adjust values for your environment.
# The backend works out-of-the-box without any .env file in local development.

# Runtime environment tag (development | staging | production)
BACKEND_ENV=development

# API version string (shown in /health response)
BACKEND_VERSION=1.0.0

# Absolute path to the directory containing output CSVs.
# Default resolves to <project_root>/outputs/ automatically — only set this
# if you store CSVs somewhere else (e.g. a mounted volume in Docker).
# OUTPUT_DIR=/absolute/path/to/outputs

# Absolute path to the directory containing the LightGBM model pkl.
# Default resolves to backend/app/models/ automatically.
# MODEL_DIR=/absolute/path/to/models

# Comma-separated list of allowed frontend origins.
# Add your deployed frontend URL here for production.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
